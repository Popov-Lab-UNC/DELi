/*
 * DELi Decoding Workflow Configuration
 *
 * Supports:
 * - Local execution (DEV): nextflow run nextflow.nf -profile local
 * - Gridengine HPC: nextflow run nextflow.nf -profile gridengine
 * - AWS Batch: nextflow run nextflow.nf -profile aws
 */

// ============================================================================
// DEFAULT SETTINGS
// ============================================================================

process {
    cpus = 1

    // Resource allocation based on process name
    withName: 'CollectDecodeChunks|CollectCountChunks' {
        memory = 16.GB
    }

    withName: '.*' {
        memory = 4.GB
    }
}

// ============================================================================
// PROFILES
// ============================================================================

profiles {

    // LOCAL EXECUTION (Development)
    local {
        process {
            executor = 'local'
            cpus = 1

            withName: 'CollectDecodeChunks|CollectCountChunks' {
                memory = 16.GB
            }

            withName: '.*' {
                memory = 4.GB
            }
        }
    }

    // GRIDENGINE HPC CLUSTER
    gridengine {
        process {
            executor = 'sge'
            penv = 'smp'  // Parallel environment for SGE
            cpus = 1
            queue = 'default'  // Adjust queue name as needed for your cluster

            withName: 'CollectDecodeChunks|CollectCountChunks' {
                memory = 16.GB
                queue = 'default'
            }

            withName: '.*' {
                memory = 4.GB
                queue = 'default'
            }
        }
    }

    // AWS BATCH
    aws {
        process {
            executor = 'awsbatch'
            queue = 'default'  // Adjust to your AWS Batch queue name
            cpus = 1

            withName: 'CollectDecodeChunks|CollectCountChunks' {
                memory = 16.GB
                queue = 'default'
            }

            withName: '.*' {
                memory = 4.GB
                queue = 'default'
            }
        }

        // AWS-specific configuration
        aws {
            region = 'us-east-1'  // Adjust to your AWS region
            batch {
                cliPath = '/home/ec2-user/miniconda/bin/aws'
            }
        }
    }
}

// ============================================================================
// TOWER/TOWER.NF INTEGRATION (Optional)
// ============================================================================

tower {
    enabled = false  // Set to true if using Nextflow Tower for monitoring
    // accessToken = 'YOUR_TOWER_TOKEN'
    // workspaceId = 'YOUR_WORKSPACE_ID'
}

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name = 'DELi Decoding Workflow'
    author = 'James Wellnitz'
    description = 'Parallel decoding workflow for DEL selection processing'
    version = '1.0'
    mainScript = 'nextflow.nf'
    nextflowVersion = '>=21.04.0'
}
